# 1. FORCE THE THREE DUMMY FILES TO TRACK CORRECTLY
*.hc linguist-language=HolyC
*.asm linguist-language=Assembly
*.ml linguist-language=OCaml

# 2. FORCE GITHUB TO BLINDLY IGNORE ALL TS AND JS FILETYPES
*.ts linguist-detectable=false
*.tsx linguist-detectable=false
*.js linguist-detectable=false
*.jsx linguist-detectable=false

# 3. GLOBAL FALLBACK TO IGNORE COMMON BUILD/NODE FOLDERS
node_modules/** linguist-vendored
dist/** linguist-vendored
build/** linguist-vendored

